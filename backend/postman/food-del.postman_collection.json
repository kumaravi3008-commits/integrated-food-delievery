              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Extract restaurantId from response",
                  "const jsonData = pm.response.json();",
                  "pm.environment.set('restaurantId', jsonData?.data?._id || jsonData?.data?.restaurantId);",
                  "pm.test('POST /api/restaurants - success', function () {",
